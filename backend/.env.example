# Backend environment variables for Render deployment
# REQUIRED: All variables must be set or the backend will fail on startup

MONGO_URI=mongodb+srv://<dbuser>:<password>@cluster0.mongodb.net/delivo?retryWrites=true&w=majority
JWT_SECRET=super_secret_jwt_key_here
FRONTEND_URL=https://your-frontend.vercel.app

# Email Configuration (Standalone nodemailer service)
# Point this at the independent email service for verification and reset emails.
EMAIL_SERVICE_URL=http://localhost:5001/api/email

# SMTP values used by the standalone service itself
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@example.com
MAIL_PASS=your-password-or-api-key
MAIL_FROM=Your App <noreply@example.com>

# Firebase Admin SDK service account configuration
# Use either FIREBASE_SERVICE_ACCOUNT_PATH or set the JSON content through FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# Optional (defaults are reasonable)
# NODE_ENV=production
# PORT=10000
