# Backend environment variables for Render deployment
# REQUIRED: All variables must be set or the backend will fail on startup

MONGO_URI=mongodb+srv://<dbuser>:<password>@cluster0.mongodb.net/delivo?retryWrites=true&w=majority
JWT_SECRET=super_secret_jwt_key_here
FRONTEND_URL=https://your-frontend.vercel.app

# Email delivery via Railway microservice
EMAIL_SERVICE_URL=https://your-email-service.up.railway.app
EMAIL_SERVICE_SECRET=replace-with-strong-random-secret

# Optional (defaults are reasonable)
# NODE_ENV=production
# PORT=10000
