# App settings
JWT_SECRET=your_jwt_secret
FRONTEND_URL=https://delivo-nu.vercel.app
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/delivo?retryWrites=true&w=majority

# SMTP settings for Spaceship Spacemail
SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FALLBACK_PORT=587
SMTP_USER=info@delivo.buzz
SMTP_PASS=your-email-password
SMTP_FROM="Delivo <info@delivo.buzz>"

# Optional timeouts (ms)
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Other settings
PORT=5000
